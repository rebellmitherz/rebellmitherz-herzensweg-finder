# Vercel/Production Environment Variables

# OpenAI API Key (PFLICHT für KI-Analyse)
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here

# Application Configuration
VITE_APP_ID=your_app_id_here
JWT_SECRET=your_jwt_secret_here

# Database Configuration
DATABASE_URL=mysql://user:password@host:port/database

# OAuth Configuration
OAUTH_SERVER_URL=https://oauth.example.com
OWNER_OPEN_ID=your_owner_open_id_here

# Forge API Configuration (optional)
BUILT_IN_FORGE_API_URL=https://api.example.com
BUILT_IN_FORGE_API_KEY=your_forge_api_key_here

# Analytics Configuration (optional)
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your_website_id_here

# Node Environment
NODE_ENV=production

env example korrigiert